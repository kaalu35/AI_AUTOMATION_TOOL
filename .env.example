GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=your-github-personal-access-token
REPO_NAME=owner/repo
GITHUB_BRANCH=main

AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=600
GEMINI_API_KEY=
ALLOW_DEMO_FALLBACK=false

TESTLINK_URL=http://localhost/testlink/lib/api/xmlrpc/v1/xmlrpc.php
TESTLINK_DEV_KEY=your-testlink-dev-key
TESTLINK_PROJECT_ID=1
TESTLINK_SUITE_ID=2
TESTLINK_AUTHOR_LOGIN=admin
TESTLINK_TESTPLAN_ID=0
TESTLINK_BUILD_NAME=Automation Pipeline Build
UPLOAD_RESULTS_TO_TESTLINK=false

ENABLE_MANTISBT_BUG_CREATION=false
MANTISBT_URL=http://localhost/mantisbt/api/rest
MANTISBT_API_TOKEN=
MANTISBT_USERNAME=
MANTISBT_PASSWORD=
MANTISBT_PROJECT_ID=0
MANTISBT_PROJECT_NAME=
MANTISBT_CATEGORY=Automation
MANTISBT_PRIORITY=normal
MANTISBT_SEVERITY=major
MANTISBT_REPRODUCIBILITY=always
MANTISBT_HANDLER_ID=0
MANTISBT_ATTACH_VIDEO=false
MANTISBT_CLOSE_ON_PASS=true
MANTISBT_REOPEN_ON_FAILURE=true
MANTISBT_CLOSED_STATUS=closed
MANTISBT_REOPEN_STATUS=feedback
MANTISBT_MAX_INLINE_ATTACHMENT_MB=8

PLAYWRIGHT_HEADLESS=false
REVIEW_GENERATED_TESTS=true
REUSE_EXISTING_TESTLINK_CASES=true
DEACTIVATE_OBSOLETE_TESTCASES=true
TESTLINK_OBSOLETE_TAG=[OBSOLETE]
ENABLE_REQUIREMENT_IMPACT_ANALYSIS=true
ENABLE_LARGE_DOCUMENT_CHUNKING=true
LARGE_DOCUMENT_CHARS=12000
DOCUMENT_CHUNK_CHARS=3500
MAX_CHUNKED_TESTCASES=40
