    {
      "name": "Add product to cart and update quantity",
      "summary": "Validates adding a product to the cart, updating its quantity, and viewing updated subtotal.",
      "steps": [
        {
          "actions": "User clicks 'Add to Cart' button for a product, then updates quantity and submits form.",
          "expected_results": "Subtotal is correctly calculated after quantity update."
        }
      ],
      "testdata": {
        "input1": "testuser2@test.com",
        "input2": "Test@123",
        "operator": "POST /cart/add",
        "expected": "Subtotal updated",
        "actions": [
          {
            "selector": "a[href='/product/1']",
            "action": "click"
          },
          {
            "selector": "input#Quantity",
            "action": "fill",
            "value": "${input2}"
          },
          {
            "selector": "button[type='submit']",
            "action": "click"
          }
        ],
        "assertions": [
          {
            "selector": "#Subtotal",
            "assertion_type": "text",
            "expected": "${expected}"
          }
        ],
        "target_url": "https://demowebshop.tricentis.com/",
        "selectors": {}
      },
      "selectors": {
        "field1": "#ProductName",
        "field2": "#Quantity",
        "submit": "button[type='submit']"
      },
      "actions": [
        {
          "selector": "a[href='/product/1']",
          "action": "click"
        },
        {
          "selector": "input#Quantity",
          "action": "fill",
          "value": "${input2}"
        },
        {
          "selector": "button[type='submit']",
          "action": "click"
        }
      ],
      "assertions": [
        {
          "selector": "#Subtotal",
          "assertion_type": "text",
          "expected": "${expected}"
        }
      ]
    },
