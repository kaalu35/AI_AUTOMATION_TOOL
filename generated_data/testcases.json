{
  "testcases": [
    {
      "name": "Login with valid credentials",
      "summary": "Validates successful login using provided email and password.",
      "steps": [
        {
          "actions": "User clicks 'Log in' button, enters valid email and password, then submits form.",
          "expected_results": "User is redirected to home page after successful login."
        }
      ],
      "testdata": {
        "input1": "testuser1@test.com",
        "input2": "Test@123",
        "operator": "POST /login",
        "expected": "Redirect to Home Page",
        "actions": [
          {
            "selector": "input#Email",
            "action": "fill",
            "value": "${input1}"
          },
          {
            "selector": "input#Password",
            "action": "fill",
            "value": "${input2}"
          },
          {
            "selector": "button[type='submit']",
            "action": "click"
          }
        ],
        "assertions": [
          {
            "selector": "a[href='/home']",
            "assertion_type": "visible",
            "expected": true
          }
        ],
        "target_url": "https://demowebshop.tricentis.com/",
        "selectors": {}
      },
      "selectors": {
        "field1": "#Email",
        "field2": "#Password",
        "submit": "button[type='submit']"
      },
      "actions": [
        {
          "selector": "input#Email",
          "action": "fill",
          "value": "${input1}"
        },
        {
          "selector": "input#Password",
          "action": "fill",
          "value": "${input2}"
        },
        {
          "selector": "button[type='submit']",
          "action": "click"
        }
      ],
      "assertions": [
        {
          "selector": "a[href='/home']",
          "assertion_type": "visible",
          "expected": true
        }
      ]
    },
